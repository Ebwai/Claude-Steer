# Dependencies
node_modules/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Hidden tool/config directories are development-only in the public release.
# Keep .github because Actions workflows are required to build installers.
**/.[!.]*/
!/.github/
!/.github/**

# Environment
.env
.env.local

# Build output
dist/
out/

# Python
__pycache__/
*.pyc
*.pyo

# Development tools
tools/

# Internal documents and plans are excluded from the public release.
# README files remain visible at every level.
/*.md
!/README.md
!/README_*.md
/**/*.md
!/**/README.md
!/**/README_*.md
/docs/
/knowledge/
/plan/
/AGENTS.md
/CLAUDE.md

# claude-driver internal notes
claude-driver/plan/
claude-driver/knowledge/
claude-driver/im.md
claude-driver/src/Code_Structure.md

